---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title="Projetos — Rotaract Mogi Guaçu" description="Conheça os projetos do Rotaract Club de Mogi Guaçu." />
	</head>
	<body class="bg-base-100 text-base-content">
		<Header />

		<main class="pt-32 pb-24 px-6">
			<div class="max-w-7xl mx-auto">
				<div class="mb-16">
					<span class="text-xs font-bold tracking-widest uppercase text-rotaract-cranberry">Impacto real</span>
					<h1 class="text-5xl sm:text-6xl font-black mt-4">Projetos</h1>
					<p class="text-base-content/60 text-lg mt-4 max-w-lg">
						Iniciativas que transformam a comunidade de Mogi Guaçu e região.
					</p>
				</div>

				<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{projects.map(project => (
						<a href={`/projetos/${project.id}`} class="group bg-base-200 rounded-3xl overflow-hidden border border-base-300 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
							<div class="h-48 bg-gradient-to-br from-rotaract-cranberry/15 to-rotary-blue/15 flex items-center justify-center">
								<Icon name="lucide:image" class="w-10 h-10 text-base-content/20" />
							</div>
							<div class="p-6">
								<div class="flex items-center gap-2 mb-3">
									<span class="text-xs font-bold tracking-wider uppercase text-rotaract-cranberry">{project.data.category}</span>
									<span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${project.data.status === 'ativo' ? 'bg-success/15 text-success' : 'bg-base-300 text-base-content/60'}`}>
										{project.data.status}
									</span>
								</div>
								<h2 class="text-lg font-black mb-2">{project.data.title}</h2>
								<p class="text-sm text-base-content/60 leading-relaxed mb-4 line-clamp-2">{project.data.description}</p>
								<div class="flex items-center justify-between">
									<span class="text-xs text-base-content/40"><FormattedDate date={project.data.pubDate} /></span>
									<span class="inline-flex items-center gap-1 text-sm font-semibold text-rotaract-cranberry group-hover:gap-2 transition-all">
										Saiba mais <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
									</span>
								</div>
							</div>
						</a>
					))}
				</div>
			</div>
		</main>

		<Footer />
	</body>
</html>
