---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import pandaHero from "../assets/panda_thor.png";

const pillars = [
    {
        icon: "lucide:heart-handshake",
        title: "Serviço",
        description:
            "Ações voluntárias que impactam diretamente a comunidade de Mogi Guaçu e região.",
    },
    {
        icon: "lucide:trending-up",
        title: "Liderança",
        description:
            "Desenvolvemos jovens capazes de inspirar e transformar o ambiente ao redor.",
    },
    {
        icon: "lucide:briefcase",
        title: "Desenvolvimento",
        description:
            "Capacitações, palestras e networking para crescimento profissional dos membros.",
    },
];

const projects = (await getCollection("projects"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);

const stats = [
    { label: "Membros ativos", value: "—" },
    { label: "Anos de história", value: "—" },
    { label: "Projetos realizados", value: "—" },
    { label: "Distrito", value: "4590" },
];

const aboutCards = [
    {
        icon: "lucide:users",
        label: "Comunidade jovem",
        desc: "Membros entre 18 e 30 anos",
    },
    {
        icon: "lucide:globe",
        label: "Impacto global",
        desc: "Parte do Rotary International",
    },
    {
        icon: "lucide:calendar",
        label: "Reuniões regulares",
        desc: "Encontros periódicos",
    },
    {
        icon: "lucide:award",
        label: "Reconhecimentos",
        desc: "Projetos premiados",
    },
];
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body class="bg-base-100 text-base-content overflow-x-hidden">
        <Header />

        <!-- ─── HERO ─────────────────────────────────────────────── -->
        <section class="relative min-h-screen flex items-center pt-16">
            <!-- Panda hero background with scroll blur -->
            <div
                class="absolute inset-0 overflow-hidden pointer-events-none"
                aria-hidden="true"
            >
                <img
                    id="hero-panda"
                    src={pandaHero.src}
                    alt=""
                    width={pandaHero.width}
                    height={pandaHero.height}
                    class="absolute inset-0 w-full h-full object-cover object-right will-change-[filter,transform]"
                    style="transform: scale(1.06); transform-origin: center right;"
                />
                <!-- Esquerda → direita: fundo para o texto (triângulo vertical) -->
                <div
                    class="absolute inset-0 bg-linear-to-r from-base-100/95 from-10% via-base-100/55 via-52% to-transparent to-72%"
                >
                </div>
                <!-- Baixo → cima: transição suave saindo da seção -->
                <div
                    class="absolute bottom-0 inset-x-0 h-[28%] bg-linear-to-t from-base-100 to-transparent"
                >
                </div>
            </div>

            <div
                class="absolute inset-0 hero-grid opacity-40 pointer-events-none"
            >
            </div>
            <div
                class="absolute top-1/4 right-0 w-xl h-xl bg-rotaract-cranberry rounded-full blur-3xl opacity-[0.07] pointer-events-none"
            >
            </div>
            <div
                class="absolute bottom-1/4 -left-24 w-80 h-80 bg-rotary-blue rounded-full blur-3xl opacity-[0.07] pointer-events-none"
            >
            </div>

            <div class="max-w-7xl mx-auto px-6 w-full py-24 relative z-10">
                <div class="max-w-4xl" data-fade>
                    <span
                        class="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase text-rotaract-cranberry mb-8"
                    >
                        <span class="w-6 h-px bg-rotaract-cranberry"></span>
                        Distrito 4590 · Mogi Guaçu, SP
                    </span>
                    <h1
                        class="text-5xl sm:text-7xl lg:text-[5.5rem] font-black leading-[0.92] tracking-tight mb-8"
                    >
                        Crie impacto<br />
                        <em class="not-italic text-rotaract-cranberry"
                            >duradouro</em
                        ><br />
                    </h1>
                    <p
                        class="text-lg sm:text-xl text-base-content/60 max-w-lg mb-10 leading-relaxed"
                    >
                        Jovens de 18 a 30 anos unidos pelo serviço à comunidade,
                        desenvolvimento profissional e liderança.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a
                            href="/sobre"
                            class="inline-flex items-center gap-2 bg-rotaract-cranberry text-white font-semibold px-8 py-4 rounded-full hover:opacity-90 transition-opacity"
                        >
                            Conheça o clube
                            <Icon name="lucide:arrow-right" class="w-4 h-4" />
                        </a>
                        <a
                            href="#projetos"
                            class="inline-flex items-center gap-2 border border-base-300 font-semibold px-8 py-4 rounded-full hover:bg-base-200 transition-colors"
                        >
                            Ver projetos
                        </a>
                    </div>
                </div>
            </div>

            <div
                class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-base-content/40 text-xs z-10"
            >
                <span class="tracking-widest uppercase">scroll</span>
                <Icon
                    name="lucide:chevron-down"
                    class="w-4 h-4 animate-bounce"
                />
            </div>
        </section>

        <!-- ─── STATS BAR ─────────────────────────────────────────── -->
        <div class="border-y border-base-300">
            <div class="max-w-7xl mx-auto px-6 py-10">
                <dl class="grid grid-cols-2 md:grid-cols-4 gap-8" data-fade>
                    {
                        stats.map((stat) => (
                            <div class="text-center">
                                <dt class="text-4xl font-black text-rotaract-cranberry tabular-nums">
                                    {stat.value}
                                </dt>
                                <dd class="text-sm text-base-content/60 mt-1">
                                    {stat.label}
                                </dd>
                            </div>
                        ))
                    }
                </dl>
            </div>
        </div>

        <!-- ─── SOBRE ─────────────────────────────────────────────── -->
        <section id="sobre" class="py-32 px-6">
            <div class="max-w-7xl mx-auto">
                <div class="grid lg:grid-cols-2 gap-20 items-center">
                    <div data-fade>
                        <span
                            class="text-xs font-bold tracking-widest uppercase text-rotaract-cranberry"
                            >Quem somos</span
                        >
                        <h2
                            class="text-4xl sm:text-5xl font-black mt-4 mb-6 leading-tight"
                        >
                            Jovens que<br />
                            <span class="text-rotaract-cranberry"
                                >transformam</span
                            ><br />
                            a comunidade.
                        </h2>
                        <p
                            class="text-base-content/60 text-lg leading-relaxed mb-8"
                        >
                            Lorem ipsum placeholder — aqui será inserida a
                            história e missão real do Rotaract Club de Mogi
                            Guaçu. Um parágrafo sobre a fundação, os valores e o
                            impacto na cidade.
                        </p>
                        <a
                            href="/sobre"
                            class="inline-flex items-center gap-2 text-rotaract-cranberry font-semibold group"
                        >
                            Nossa história
                            <Icon
                                name="lucide:arrow-right"
                                class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                            />
                        </a>
                    </div>

                    <div class="grid grid-cols-2 gap-4" data-fade>
                        {
                            aboutCards.map((card) => (
                                <div class="bg-base-200 rounded-2xl p-6 border border-base-300 hover:border-rotaract-cranberry/30 transition-colors">
                                    <Icon
                                        name={card.icon}
                                        class="w-6 h-6 text-rotaract-cranberry mb-4"
                                    />
                                    <p class="font-semibold text-sm mb-1">
                                        {card.label}
                                    </p>
                                    <p class="text-xs text-base-content/60">
                                        {card.desc}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── PILARES ───────────────────────────────────────────── -->
        <section class="py-24 px-6 bg-base-200">
            <div class="max-w-7xl mx-auto">
                <div class="text-center mb-16" data-fade>
                    <span
                        class="text-xs font-bold tracking-widest uppercase text-rotaract-cranberry"
                        >O que nos move</span
                    >
                    <h2 class="text-4xl sm:text-5xl font-black mt-4">
                        Nossos pilares
                    </h2>
                </div>
                <div class="grid md:grid-cols-3 gap-6">
                    {
                        pillars.map((pillar) => (
                            <div
                                class="bg-base-100 rounded-3xl p-8 border border-base-300 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
                                data-fade
                            >
                                <div class="w-12 h-12 rounded-2xl bg-rotaract-cranberry/10 flex items-center justify-center mb-6">
                                    <Icon
                                        name={pillar.icon}
                                        class="w-6 h-6 text-rotaract-cranberry"
                                    />
                                </div>
                                <h3 class="text-xl font-black mb-3">
                                    {pillar.title}
                                </h3>
                                <p class="text-base-content/60 leading-relaxed">
                                    {pillar.description}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ─── PROJETOS ──────────────────────────────────────────── -->
        <section id="projetos" class="py-32 px-6">
            <div class="max-w-7xl mx-auto">
                <div class="flex items-end justify-between mb-16" data-fade>
                    <div>
                        <span
                            class="text-xs font-bold tracking-widest uppercase text-rotaract-cranberry"
                            >Impacto real</span
                        >
                        <h2 class="text-4xl sm:text-5xl font-black mt-4">
                            Projetos
                        </h2>
                    </div>
                    <a
                        href="/projetos"
                        class="hidden md:inline-flex items-center gap-2 text-sm font-semibold text-base-content/40 hover:text-rotaract-cranberry transition-colors"
                    >
                        Ver todos <Icon
                            name="lucide:arrow-right"
                            class="w-4 h-4"
                        />
                    </a>
                </div>
                <div class="grid md:grid-cols-3 gap-6">
                    {
                        projects.map((project) => (
                            <a
                                href={`/projetos/${project.id}`}
                                class="group bg-base-200 rounded-3xl overflow-hidden border border-base-300 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
                                data-fade
                            >
                                <div class="h-48 bg-gradient-to-br from-rotaract-cranberry/15 to-rotary-blue/15 flex items-center justify-center">
                                    <Icon
                                        name="lucide:image"
                                        class="w-10 h-10 text-base-content/20"
                                    />
                                </div>
                                <div class="p-6">
                                    <span class="text-xs font-bold tracking-wider uppercase text-rotaract-cranberry">
                                        {project.data.category}
                                    </span>
                                    <h3 class="text-lg font-black mt-2 mb-3">
                                        {project.data.title}
                                    </h3>
                                    <p class="text-sm text-base-content/60 leading-relaxed mb-5">
                                        {project.data.description}
                                    </p>
                                    <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-rotaract-cranberry group-hover:gap-2.5 transition-all">
                                        Saiba mais{" "}
                                        <Icon
                                            name="lucide:arrow-right"
                                            class="w-3.5 h-3.5"
                                        />
                                    </span>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ─── CTA ───────────────────────────────────────────────── -->
        <section id="junte-se" class="px-6 pb-16" data-fade>
            <div class="max-w-7xl mx-auto">
                <div
                    class="bg-rotaract-cranberry rounded-3xl px-8 py-24 text-center text-white relative overflow-hidden"
                >
                    <div
                        class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/3 pointer-events-none"
                    >
                    </div>
                    <div
                        class="absolute bottom-0 left-0 w-64 h-64 bg-white/10 rounded-full translate-y-1/2 -translate-x-1/3 pointer-events-none"
                    >
                    </div>
                    <div class="relative max-w-2xl mx-auto">
                        <h2 class="text-4xl sm:text-5xl font-black mb-4">
                            Faça parte do movimento.
                        </h2>
                        <p class="text-white/70 text-lg mb-10 leading-relaxed">
                            Se você tem entre 18 e 30 anos e quer fazer a
                            diferença, o Rotaract tem um lugar para você.
                        </p>
                        <a
                            href="https://www.instagram.com/rotaractmguacu/"
                            target="_blank"
                            rel="noopener"
                            class="inline-flex items-center gap-2 bg-white text-rotaract-cranberry font-bold px-8 py-4 rounded-full hover:scale-105 transition-transform"
                        >
                            Entre em contato
                            <Icon name="lucide:instagram" class="w-4 h-4" />
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <Footer />
    </body>
</html>

<script>
    import { animate, inView } from "motion";

    inView("[data-fade]", ({ target }) => {
        animate(
            target,
            { opacity: [0, 1], y: [40, 0] },
            { duration: 0.75, ease: [0.16, 1, 0.3, 1] },
        );
    });

    // Blur progressivo da imagem hero ao rolar
    const pandaEl = document.getElementById(
        "hero-panda",
    ) as HTMLImageElement | null;
    if (pandaEl) {
        const updateHeroBlur = () => {
            const progress = Math.min(window.scrollY / window.innerHeight, 1);
            const blur = progress * 22;
            const scale = 1.06 + progress * 0.06;
            pandaEl.style.filter = `blur(${blur}px)`;
            pandaEl.style.transform = `scale(${scale})`;
        };
        window.addEventListener("scroll", updateHeroBlur, { passive: true });
        updateHeroBlur();
    }
</script>
