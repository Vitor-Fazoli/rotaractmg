---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"projects">["data"];

const { title, description, pubDate, category, heroImage, status } =
    Astro.props;
---

<html lang="pt-BR">
    <head>
        <BaseHead title={title} description={description} />
    </head>
    <body class="bg-base-100 text-base-content">
        <Header />

        <main class="pt-16">
            <div
                class="relative h-64 sm:h-80 bg-gradient-to-br from-rotaract-cranberry/20 to-rotary-blue/20 flex items-end"
            >
                {
                    heroImage && (
                        <Image
                            src={heroImage}
                            alt={title}
                            width={1200}
                            height={400}
                            class="absolute inset-0 w-full h-full object-cover"
                        />
                    )
                }
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"
                >
                </div>
                <div class="relative max-w-3xl mx-auto px-6 pb-8 w-full">
                    <div class="flex items-center gap-3 mb-3">
                        <span
                            class="text-xs font-bold tracking-wider uppercase text-rotaract-cranberry bg-white/10 backdrop-blur-sm px-3 py-1 rounded-full border border-white/20"
                        >
                            {category}
                        </span>
                        <span
                            class={`text-xs font-semibold px-3 py-1 rounded-full ${status === "ativo" ? "bg-success/20 text-white" : "bg-white/10 text-white/70"}`}
                        >
                            {status}
                        </span>
                    </div>
                    <h1
                        class="text-3xl sm:text-4xl font-black text-white leading-tight"
                    >
                        {title}
                    </h1>
                </div>
            </div>

            <div class="max-w-3xl mx-auto px-6 py-16">
                <div
                    class="flex items-center gap-2 text-sm text-base-content/40 mb-12 pb-8 border-b border-base-300"
                >
                    <Icon name="lucide:calendar" class="w-4 h-4" />
                    <FormattedDate date={pubDate} />
                </div>

                <div
                    class="prose max-w-none
					prose-headings:font-black prose-headings:text-base-content
					prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
					prose-p:text-base-content/70 prose-p:leading-relaxed
					prose-a:text-rotaract-cranberry prose-a:no-underline hover:prose-a:underline
					prose-strong:text-base-content"
                >
                    <slot />
                </div>

                <div class="mt-16 pt-8 border-t border-base-300">
                    <a
                        href="/projetos"
                        class="inline-flex items-center gap-2 text-sm font-semibold text-base-content/50 hover:text-rotaract-cranberry transition-colors"
                    >
                        <Icon name="lucide:arrow-left" class="w-4 h-4" />
                        Todos os projetos
                    </a>
                </div>
            </div>
        </main>

        <Footer />
    </body>
</html>
