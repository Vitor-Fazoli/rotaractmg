---
import { Icon } from 'astro-icon/components';

const today = new Date();
---

<footer class="border-t border-base-300">
	<div class="max-w-7xl mx-auto px-6 py-16">
		<div class="grid sm:grid-cols-3 gap-12 mb-16">
			<div>
				<a href="/" class="font-black text-xl mb-4 block">
					<span class="text-rotaract-cranberry">Rotaract</span> Mogi Guaçu
				</a>
				<p class="text-sm text-base-content/60 leading-relaxed max-w-xs">
					Jovens em serviço à comunidade de Mogi Guaçu e região. Distrito 4590 · Rotary International.
				</p>
			</div>

			<div>
				<h3 class="font-bold text-sm mb-5">Navegação</h3>
				<ul class="space-y-3 text-sm text-base-content/60">
					<li><a href="/" class="hover:text-rotaract-cranberry transition-colors">Início</a></li>
					<li><a href="/sobre" class="hover:text-rotaract-cranberry transition-colors">Sobre</a></li>
					<li><a href="/projetos" class="hover:text-rotaract-cranberry transition-colors">Projetos</a></li>
					<li><a href="/blog" class="hover:text-rotaract-cranberry transition-colors">Blog</a></li>
				</ul>
			</div>

			<div>
				<h3 class="font-bold text-sm mb-5">Redes sociais</h3>
				<div class="flex gap-3">
					<a
						href="https://www.instagram.com/rotaractmguacu/"
						target="_blank"
						rel="noopener"
						aria-label="Instagram"
						class="w-10 h-10 rounded-full border border-base-300 flex items-center justify-center text-base-content/60 hover:text-rotaract-cranberry hover:border-rotaract-cranberry transition-colors"
					>
						<Icon name="lucide:instagram" class="w-4 h-4" />
					</a>
					<a
						href="https://www.facebook.com/rotaractmogiguacu/?locale=pt_BR"
						target="_blank"
						rel="noopener"
						aria-label="Facebook"
						class="w-10 h-10 rounded-full border border-base-300 flex items-center justify-center text-base-content/60 hover:text-rotaract-cranberry hover:border-rotaract-cranberry transition-colors"
					>
						<Icon name="lucide:facebook" class="w-4 h-4" />
					</a>
					<a
						href="https://br.linkedin.com/in/rotaractmguacu"
						target="_blank"
						rel="noopener"
						aria-label="LinkedIn"
						class="w-10 h-10 rounded-full border border-base-300 flex items-center justify-center text-base-content/60 hover:text-rotaract-cranberry hover:border-rotaract-cranberry transition-colors"
					>
						<Icon name="lucide:linkedin" class="w-4 h-4" />
					</a>
				</div>
			</div>
		</div>

		<div class="border-t border-base-300 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-base-content/40">
			<p>&copy; {today.getFullYear()} Rotaract Club de Mogi Guaçu. Todos os direitos reservados.</p>
			<p>Distrito 4590 · Rotary International</p>
		</div>
	</div>
</footer>
