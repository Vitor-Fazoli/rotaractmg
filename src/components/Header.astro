---
import { Icon } from "astro-icon/components";
import logo from "../assets/rotaract_mguacu_logo.png";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
---

<header
    id="site-header"
    class="fixed top-0 inset-x-0 z-50 transition-all duration-300"
>
    <SpeedInsights />
    <Analytics />
    <div class="max-w-7xl mx-auto px-6">
        <nav class="flex items-center justify-between h-16">
            <a href="/">
                <img
                    src={logo.src}
                    alt="Rotaract Club de Mogi Guaçu"
                    class="h-16 w-auto"
                />
            </a>

            <div class="hidden md:flex items-center gap-1">
                <a
                    href="/"
                    class="px-4 py-2 text-sm font-medium rounded-full hover:bg-base-200 transition-colors"
                    >Início</a
                >
                <a
                    href="/sobre"
                    class="px-4 py-2 text-sm font-medium rounded-full hover:bg-base-200 transition-colors"
                    >Sobre</a
                >
                <a
                    href="/projetos"
                    class="px-4 py-2 text-sm font-medium rounded-full hover:bg-base-200 transition-colors"
                    >Projetos</a
                >
                <a
                    href="/blog"
                    class="px-4 py-2 text-sm font-medium rounded-full hover:bg-base-200 transition-colors"
                    >Blog</a
                >
                <a
                    href="/junte-se"
                    class="px-4 py-2 text-sm font-medium rounded-full hover:bg-base-200 transition-colors"
                    >Junte-se</a
                >
            </div>

            <div class="flex items-center gap-2">
                <button
                    id="theme-toggle"
                    aria-label="Alternar tema"
                    class="p-2 rounded-full hover:bg-base-200 transition-colors text-base-content/60"
                >
                    <Icon name="lucide:sun" class="w-4 h-4 block dark:hidden" />
                    <Icon
                        name="lucide:moon"
                        class="w-4 h-4 hidden dark:block"
                    />
                </button>
                <a
                    href="/junte-se"
                    class="bg-rotaract-cranberry text-white text-sm font-semibold px-5 py-2 rounded-full hover:opacity-90 transition-opacity hidden sm:block"
                >
                    Participar
                </a>
            </div>
        </nav>
    </div>
</header>

<script>
    const header = document.getElementById("site-header");
    const html = document.documentElement;
    const toggle = document.getElementById("theme-toggle");

    const onScroll = () =>
        header?.classList.toggle("scrolled", window.scrollY > 20);
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    toggle?.addEventListener("click", () => {
        const next =
            html.getAttribute("data-theme") === "dark" ? "light" : "dark";
        html.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
    });
</script>
